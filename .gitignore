# R session files
.Rhistory
.RData
.Rproj.user/
*.Rproj.user

# renv (track lockfile and activate script; ignore library)
renv/library/
renv/staging/
renv/sandbox/

# Output (regenerated by pipeline)
/output/

# Data (fetched at runtime)
/data/

# OS files
.DS_Store
Thumbs.db

# Temporary files
*.tmp

# CBO Excel source files (populate locally; see README)
/input/budget_projections/*.xls
/input/budget_projections/*.xlsx
/input/economic_projections/*.xls
/input/economic_projections/*.xlsx
